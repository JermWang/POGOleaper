# ---------------------------------------------------------------------------
# Pogo Poker — environment template. Copy to `.env` and fill in.
# NEVER commit a real .env. Private keys must only ever live server-side.
# ---------------------------------------------------------------------------

# Postgres connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pogo_poker?schema=public"

# Redis used for table state, locks, and pub/sub between web + ws processes.
REDIS_URL="redis://localhost:6379"

# Privy auth (https://dashboard.privy.io). The public app id is exposed to the client.
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_SECRET=""

# Robinhood Chain (EVM, Arbitrum Orbit L2). Mainnet = 4663, testnet = 46630.
# Point at the testnet RPC + chain id during development.
ROBINHOOD_RPC_URL="https://rpc.mainnet.chain.robinhood.com"
ROBINHOOD_CHAIN_ID="4663"
ROBINHOOD_EXPLORER_URL="https://robinhoodchain.blockscout.com"

# Server-side hot wallet (0x-prefixed hex private key) used to send withdrawals
# and anchor transactions. SERVER ONLY. Never expose. In production use a
# KMS / signing service instead.
HOT_WALLET_PRIVATE_KEY=""

# Treasury address (0x…) that aggregates user deposits.
TREASURY_WALLET_ADDRESS=""

# ERC-20 contract address for USDC on Robinhood Chain (0x…). Leave empty to
# disable USDC play until the canonical deployment address is known.
USDC_TOKEN_ADDRESS=""

# The $POGO house token (ERC-20, 0x…). Public tables are token-only; private
# tables may use ETH, USDC, or this token. Leave empty to disable token play.
# The address is server-only; decimals + symbol are NEXT_PUBLIC_ so the client
# can format and label token amounts.
POGO_TOKEN_ADDRESS=""
NEXT_PUBLIC_TOKEN_DECIMALS="18"
NEXT_PUBLIC_TOKEN_SYMBOL="POGO"

# Admins by email (if a wallet has a linked email) and/or by wallet address
# (0x…, case-insensitive). Wallet-only logins typically have no email, so set
# ADMIN_WALLETS.
ADMIN_EMAILS="admin@example.com"
ADMIN_WALLETS=""

# When true, the mock compliance provider auto-approves KYC/geo in DEV ONLY.
# MUST be false in production. Business logic never hard-codes approval.
ENABLE_DEV_COMPLIANCE_APPROVAL="true"

# Withdrawals at or above this wei amount require manual admin review.
MIN_WITHDRAWAL_REVIEW_WEI="100000000000000000"

# Confirmations required before a deposit is credited to the internal ledger.
DEPOSIT_CONFIRMATIONS="32"

# Max concurrent private tables (server-overload guard). Hosting is blocked
# with a "please wait" message once this many private games are live.
MAX_PRIVATE_TABLES="50"

# Table voice/video via LiveKit. Leave empty to disable mic/camera at tables.
# Create a project at https://cloud.livekit.io — URL is public (wss://…); the
# key + secret are server-only (used to mint short-lived join tokens).
NEXT_PUBLIC_LIVEKIT_URL=""
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# Port for the standalone realtime poker WebSocket server (`npm run ws`).
WS_PORT="3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
